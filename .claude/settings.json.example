{
  "permissions": {
    "allow": [
      "Bash([YOUR_TEST_COMMAND])",
      "Bash([YOUR_TYPECHECK_COMMAND])",
      "Bash(npm run dev)",
      "Bash(npm test -- --reporter=verbose)",
      "Bash(git commit:*)",
      "Bash(git status -u)",
      "Bash(git pull:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)",
      "Bash(/usr/bin/git:*)"
    ],
    "additionalDirectories": [
      "[YOUR_PROJECT_ROOT]"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | { read -r cmd; if echo \"$cmd\" | grep -qE '^(git|/usr/bin/git) commit'; then cd [YOUR_APP_DIR] && [YOUR_TYPECHECK_COMMAND] 2>&1; exit_code=$?; if [ $exit_code -ne 0 ]; then echo '{\"decision\":\"block\",\"reason\":\"Type check failed. Fix errors before committing.\"}'; else echo '{\"decision\":\"allow\",\"reason\":\"Type check passed\"}'; fi; fi; }",
            "timeout": 120,
            "statusMessage": "Running pre-commit type check..."
          }
        ]
      }
    ]
  }
}
